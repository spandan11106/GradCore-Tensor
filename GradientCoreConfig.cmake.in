@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Ensure OpenMP is found when GradientCore is used
find_dependency(OpenMP REQUIRED)

# Include the targets exported by install(EXPORT ...)
include("${CMAKE_CURRENT_LIST_DIR}/GradientCoreTargets.cmake")

# Check that required components are available
check_required_components(GradientCore)
